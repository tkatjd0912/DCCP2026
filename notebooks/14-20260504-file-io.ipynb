   "source": [
    "text = \"the cat sat on the mat the cat slept\"\n",
    "words = text.split()\n",
    "freq = {}\n",
    "\n",
    "for w in words:\n",
    "    freq[w] = freq.get(w, 0) + 1\n",
    "    \n",
    "with open('freq.txt', 'w', encoding = 'utf-8') as f:\n",
    "    for  (word, count) in sorted(freq.items()):\n",
    "        f.write(f'{word}\\t{count}\\n')"
   ]
